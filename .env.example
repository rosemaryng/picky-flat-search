# Copy to .env and fill in what you have. Everything is optional — the app runs
# offline with deterministic fallbacks when a key is missing.

# --- LLM (brief parsing, floorplan vision, smart scoring) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Shared memory / store ---
# "modal" -> a named modal.Dict every agent can attach to (set automatically in
# the Modal workers). Leave blank for local JSON (local_db.json) in dev.
FLATFINDER_STORE=
MODAL_DICT_NAME=flatfinder-shared

# --- PayPal sandbox (revenue; else payments are simulated) ---
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_BASE=https://api-m.sandbox.paypal.com

# --- Enrichment (all optional / free) ---
EPC_API_KEY=          # base64 of "email:apikey" from epc.opendatacommunities.org
TFL_APP_KEY=          # raises TfL rate limits (optional)

# --- Search defaults ---
RIGHTMOVE_REGION=87490   # London

# --- Safety: only set to 1 if you accept the ToS/anti-bot risks ---
ALLOW_AUTO_SUBMIT=
